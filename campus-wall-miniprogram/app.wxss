/*app.wxss 全局样式*/
page {
  background-color: #c4a882;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
}

.container {
  min-height: 100vh;
}

/* 通用按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #c4a882, #a08060);
  color: #fff;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
}

/* 通用卡片样式 */
.card {
  background: #f5f0e0;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(90,61,0,0.15);
}