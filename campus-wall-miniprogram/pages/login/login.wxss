/*pages/login/login.wxss — 已适配屏幕尺寸 */
.container {
  min-height: 100vh;
  background-color: #c4a882;
  background-image:
    repeating-linear-gradient(0deg,
      transparent 0%, transparent 49.167%,
      rgba(0,0,0,0.12) 49.167%, rgba(0,0,0,0.12) 50.833%,
      transparent 50.833%, transparent 100%),
    repeating-linear-gradient(90deg,
      transparent 0%, transparent 49.583%,
      rgba(0,0,0,0.12) 49.583%, rgba(0,0,0,0.12) 50.417%,
      transparent 50.417%, transparent 100%),
    repeating-linear-gradient(0deg,
      rgba(180,140,100,0.3) 0%,
      rgba(200,160,120,0.1) 25%,
      rgba(170,130,90,0.2) 50%,
      rgba(190,150,110,0.15) 75%,
      rgba(175,135,95,0.25) 100%);
  background-size: 480rpx 240rpx;
  padding: 20rpx;
}

.header {
  padding: 60rpx 20rpx;
  text-align: center;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #5a3d00;
  animation: slideUp 0.4s ease-out;
}

.scan-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #f5f0e0;
  border-radius: 20rpx;
  padding: 60rpx;
  margin: 40rpx 20rpx;
  border: 4rpx dashed #c4a882;
  animation: slideUp 0.4s ease-out 0.2s both;
}

.scan-box:active {
  background: #eae5d8;
}

.scan-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  animation: pulse 2s ease-in-out infinite;
}

.scan-text {
  font-size: 32rpx;
  color: #5a3d00;
  font-weight: bold;
}

.tips {
  background: #f5f0e0;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx;
  animation: slideUp 0.4s ease-out 0.4s both;
}

.tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #5a3d00;
  margin-bottom: 20rpx;
}

.tip-text {
  display: block;
  font-size: 26rpx;
  color: #8b7355;
  margin-bottom: 10rpx;
}

.status {
  text-align: center;
  padding: 30rpx;
  animation: fadeIn 0.4s ease-out;
}

.status-text {
  font-size: 28rpx;
  color: #5a3d00;
}

.manual-input-box {
  background: #f5f0e0;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx;
  animation: slideUp 0.4s ease-out 0.6s both;
}

.manual-input {
  flex: 1;
  height: 72rpx;
  background: #fff;
  border: 2rpx solid #c4a882;
  border-radius: 12rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
  color: #5a3d00;
}

.manual-btn {
  padding: 0 24rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: linear-gradient(135deg, #c4a882, #a08060);
  color: #fff;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: bold;
  border: none;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
}