/*pages/notice/notice.wxss — 已适配屏幕尺寸 (flex布局) */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  background-color: #c4a882;
  background-image:
    repeating-linear-gradient(0deg,
      transparent 0%, transparent 49.167%,
      rgba(0,0,0,0.12) 49.167%, rgba(0,0,0,0.12) 50.833%,
      transparent 50.833%, transparent 100%),
    repeating-linear-gradient(90deg,
      transparent 0%, transparent 49.583%,
      rgba(0,0,0,0.12) 49.583%, rgba(0,0,0,0.12) 50.417%,
      transparent 50.417%, transparent 100%),
    repeating-linear-gradient(0deg,
      rgba(180,140,100,0.3) 0%,
      rgba(200,160,120,0.1) 25%,
      rgba(170,130,90,0.2) 50%,
      rgba(190,150,110,0.15) 75%,
      rgba(175,135,95,0.25) 100%);
  background-size: 480rpx 240rpx;
  padding: 20rpx;
}

.header {
  flex-shrink: 0;
  padding: 30rpx 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #5a3d00;
  animation: slideUp 0.4s ease-out;
}

.tabs {
  flex-shrink: 0;
  display: flex;
  background: #f5f0e0;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
  animation: slideUp 0.4s ease-out 0.1s both;
}

.tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #8b7355;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.tab.active {
  background: #c4a882;
  color: #5a3d00;
  font-weight: bold;
  transform: scale(1.02);
}

.notice-list {
  flex: 1;
  min-height: 0;
}

.notice-item {
  display: flex;
  align-items: center;
  background: #fff9e6;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(90,61,0,0.15);
  transition: all 0.3s ease;
}

.notice-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(90,61,0,0.1);
}

.notice-item.unread {
  background: #fffde7;
  border-left: 6rpx solid #f5a623;
}

.notice-icon {
  width: 80rpx;
  height: 80rpx;
  background: #c4a882;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.notice-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.notice-title {
  font-size: 30rpx;
  color: #5a3d00;
  font-weight: bold;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
}

.notice-time {
  font-size: 22rpx;
  color: #a08060;
  margin-top: 4rpx;
}

.unread-dot {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 16rpx;
  height: 16rpx;
  background: #ff4d4f;
  border-radius: 50%;
  animation: pulse 2s ease-in-out infinite;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  animation: fadeIn 0.4s ease-out;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  animation: bounce 2s ease-in-out infinite;
}

.empty-text {
  font-size: 28rpx;
  color: #8b7355;
}

/* 详情视图 */
.detail-view {
  flex: 1;
  min-height: 0;
  overflow-x: hidden;
  background: #fff9e6;
  border-radius: 20rpx;
  padding: 30rpx;
  padding-bottom: 40rpx;
  animation: fadeIn 0.3s ease;
}

.detail-header {
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #e8e0d0;
}

.detail-back {
  font-size: 26rpx;
  color: #8b7355;
  display: block;
  margin-bottom: 16rpx;
  padding: 8rpx 0;
}

.detail-back:active { opacity: 0.6; }

.detail-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #5a3d00;
  display: block;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.detail-type {
  font-size: 22rpx;
  color: #c4a882;
  background: #f5f0e0;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  display: inline-block;
  margin-bottom: 8rpx;
}

.detail-time {
  font-size: 22rpx;
  color: #a08060;
  display: block;
  margin-top: 8rpx;
}

.detail-body {
  line-height: 1.8;
  font-size: 28rpx;
  color: #5a3d00;
  word-break: break-word;
  overflow-wrap: break-word;
  white-space: normal;
}

/* Markdown 渲染样式覆盖 rich-text 内部 */
.detail-body rich-text,
.markdown-content {
  line-height: 1.8;
  font-size: 28rpx;
  color: #5a3d00;
  word-break: break-word;
  overflow-wrap: break-word;
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.7; transform: scale(1.2); }
}
