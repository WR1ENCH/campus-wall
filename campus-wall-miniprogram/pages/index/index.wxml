<!--pages/index/index.wxml-->
<view class="container">
  <view class="header">
    <text class="title">我的</text>
  </view>

  <view class="user-card" wx:if="{{loggedIn}}">
    <image class="avatar" src="{{userInfo.avatar || '/icons/default-avatar.png'}}" mode="aspectFill"/>
    <view class="info">
      <text class="nickname">{{userInfo.nickname || '用户'}}</text>
      <text class="uid">ID: {{userInfo.id || '-'}}</text>
    </view>
  </view>

  <view class="login-box" wx:if="{{!loggedIn}}">
    <view class="login-icon">🔐</view>
    <text class="login-text">登录后查看通知</text>
    <view class="login-btn" bindtap="login">
      <text>立即登录</text>
    </view>
  </view>

  <view class="menu" wx:if="{{loggedIn}}">
    <view class="menu-item" bindtap="logout">
      <text class="icon">🚪</text>
      <text class="text">退出登录</text>
      <text class="arrow">›</text>
    </view>
  </view>
</view>