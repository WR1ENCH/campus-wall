/*pages/index/index.wxss — 已适配屏幕尺寸 */
.container {
  min-height: 100vh;
  background-color: #c4a882;
  background-image:
    /* 水平线：每格一条 2rpx 线 */
    repeating-linear-gradient(0deg,
      transparent 0%, transparent 49.167%,
      rgba(0,0,0,0.12) 49.167%, rgba(0,0,0,0.12) 50.833%,
      transparent 50.833%, transparent 100%),
    /* 垂直线：每格一条 2rpx 线 */
    repeating-linear-gradient(90deg,
      transparent 0%, transparent 49.583%,
      rgba(0,0,0,0.12) 49.583%, rgba(0,0,0,0.12) 50.417%,
      transparent 50.417%, transparent 100%),
    /* 颜色渐变 overlay */
    repeating-linear-gradient(0deg,
      rgba(180,140,100,0.3) 0%,
      rgba(200,160,120,0.1) 25%,
      rgba(170,130,90,0.2) 50%,
      rgba(190,150,110,0.15) 75%,
      rgba(175,135,95,0.25) 100%);
  background-size: 480rpx 240rpx;
  padding: 20rpx;
}

.header {
  padding: 30rpx 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #5a3d00;
}

.user-card {
  display: flex;
  align-items: center;
  background: #f5f0e0;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  animation: slideUp 0.4s ease-out;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #c4a882;
  margin-right: 20rpx;
  animation: scaleIn 0.3s ease-out;
}

.info {
  display: flex;
  flex-direction: column;
  animation: fadeIn 0.4s ease-out 0.1s both;
}

.nickname {
  font-size: 32rpx;
  font-weight: bold;
  color: #5a3d00;
}

.uid {
  font-size: 24rpx;
  color: #8b7355;
}

.login-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #f5f0e0;
  border-radius: 20rpx;
  padding: 60rpx 30rpx;
  animation: slideUp 0.4s ease-out;
}

.login-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  animation: bounce 2s ease-in-out infinite;
}

.login-text {
  font-size: 28rpx;
  color: #8b7355;
  margin-bottom: 30rpx;
}

.login-btn {
  background: linear-gradient(135deg, #c4a882, #a08060);
  color: #fff;
  text-align: center;
  padding: 24rpx 80rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 20rpx rgba(90,61,0,0.3);
  animation: fadeIn 0.4s ease-out 0.2s both;
}

.menu {
  background: #f5f0e0;
  border-radius: 20rpx;
  overflow: hidden;
  animation: slideUp 0.4s ease-out 0.3s both;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #e8e0d0;
}

.menu-item:last-child {
  border-bottom: none;
}

.icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.text {
  flex: 1;
  font-size: 30rpx;
  color: #5a3d00;
}

.arrow {
  font-size: 36rpx;
  color: #b8a080;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.8);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}