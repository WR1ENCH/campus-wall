# ===== 校园墙 (Campus Wall) 环境变量配置 =====

# 敏感词库解密密钥（32字节 hex，必需）
# 用于解密 tencent_sensitive_words.enc 加密词库
# 生成新密钥: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SENSITIVE_KEY=your-64-char-hex-key-here

# Token 签名密钥（可选，不设置则每次重启随机生成，导致所有用户 token 失效）
# TOKEN_SECRET=your-random-secret

# 实名信息加密密钥（可选，不设置则使用默认值，安全性降低）
# CERT_ENC_SECRET=your-other-secret

# 服务端口（可选，默认 3000）
# PORT=3000
